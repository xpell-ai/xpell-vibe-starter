{
  "_id": "flow-create-app-from-starter",
  "_on_success": [
    {
      "_module": "xdb-client",
      "_op": "save_string",
      "_params": {
        "_key": "xvibe.active_app",
        "_value": "$flow._last._result._app_id",
        "_debug": true
      }
    }
  ],
  "_steps": [
    {
      "_id": "create-app",
      "_command": {
        "_module": "xvibe",
        "_op": "create_app_from_starter",
        "_params": {
          "_debug": true,
          "_starter_id": "$event._starter_id",
          "_app_id": "$event._app_id",
          "_env": "default",
          "_vision": "$event._vision"
        }
      }
    }
  ]
}
