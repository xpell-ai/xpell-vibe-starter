{
  "_id": "main",
  "_type": "view",
  "style": "position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#111;color:white;",
  "_children": [
    {
      "_type": "view",
      "style": "width:600px;display:flex;flex-direction:column;gap:20px;padding:40px;",
      "_children": [
        {
          "_type": "label",
          "_text": "What do you want to build?"
        },
        {
          "_type": "text",
          "_id": "app-id",
          "rows": 5,
          "style": "width:100%;background:#222;color:white;padding:10px;border:1px solid #333;",
          "placeholder": "App id: e.g. todo-app, game, etc.",
          "_text":"my-app",
          "_on": {
            "change": {
              "_module": "xd",
              "_op": "set",
              "_params": {
                "key": "vibe.app_id",
                "value": "$event.target.value",
                "_debug": true
              }
            }
          }
        },
        {
          "_type": "textarea",
          "_id": "prompt-input",
          "rows": 5,
          "style": "width:100%;background:#222;color:white;padding:10px;border:1px solid #333;",
          "placeholder": "E.g. A todo app with React, a game with Phaser, etc.",
          "_on": {
            "change": {
              "_module": "xd",
              "_op": "set",
              "_params": {
                "key": "vibe.prompt",
                "value": "$event.target.value",
                "_debug": true
              }
            }
          }
        },
        {
          "_type": "button",
          "_text": "Generate App",
          "_flow": {
            "_id": "flow-generate-app",
            "_payload": {
              "_prompt": "$xdata.vibe.prompt",
              "_app_id": "$xdata.vibe.app_id"
            }
          }
        }
      ]
    }
  ]
}