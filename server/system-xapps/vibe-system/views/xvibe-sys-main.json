{
  "_id": "xvibe-sys-main",
  "_type": "view",
  "_theme": "terminal",
  "_children": [
    {
      "_type": "style-sheet",
      "_href": "http://localhost:3000/public/custom.css",
      "_classes": {}
    },
    {
      "_type": "stack",
      "class": "page-shell",
      "_gap": 0,
      "_children": [
        {
          "_id": "page-toolbar",
          "_type": "view",
          "class": "page-toolbar",
          "_on": {
            "_wormhole-open": {
              "_module": "xai-client",
              "_op": "get-provider-status",
              "_params": {
                "_provider": "aime",
                "_result_key": "ai.connection"
              }
            }
          },
          "_children": [
            {
              "_type": "stack",
              "class": "page-toolbar__left",
              "_children": [
                {
                  "_type": "label",
                  "_text": "Xpell Vibe",
                  "class": "page-title"
                },
                {
                  "_type": "label",
                  "_text": "Create a starter app, then evolve it live with Xpell Vibe Studio.",
                  "class": "page-subtitle"
                }
              ]
            },
            {
              "_type": "stack",
              "class": "page-toolbar__right",
              "_children": [
                {
                  "_type": "xselect",
                  "class": "toolbar-theme-select",
                  "_value": "terminal",
                  "_options": [
                    {
                      "value": "terminal",
                      "label": "Theme: Terminal"
                    },
                    {
                      "value": "dark",
                      "label": "Theme: Dark"
                    },
                    {
                      "value": "light",
                      "label": "Theme: Light"
                    }
                  ],
                  "_on_change": {
                    "_module": "xui",
                    "_op": "apply-theme",
                    "_params": {
                      "_theme": "$data"
                    }
                  }
                },
                {
                  "_type": "label",
                  "_data_source": "ai.connection",
                  "_text": "AI: checking...",
                  "_on_data": {
                    "_op": "set-text-from-data",
                    "_params": {
                      "data": "$data",
                      "path": "_connected",
                      "map": {
                        "true": "🟢 AI connected",
                        "false": "🔴 AI offline"
                      }
                    }
                  }
                },
                {
                  "_type": "link",
                  "_text": "API Key",
                  "_on": {
                    "_click": {
                      "_op": "open-object",
                      "_params": {
                        "_id": "api-key-modal"
                      }
                    }
                  }
                },
                {
                  "_type": "link",
                  "_text": "Developer Console",
                  "href": "https://console.xpell.ai",
                  "target": "_blank"
                }
              ]
            }
          ]
        },
        {
          "_id": "generated-apps-panel",
          "_type": "stack",
          "class": "panel apps-panel ",
          "_gap": 0,
          "_children": [
            {
              "_type": "label",
              "_text": "Generated Apps",
              "class": "panel-title"
            },
            {
              "_type": "label",
              "_text": "Load apps you've created with VIBE Studio here. System apps are hidden by default.",
              "class": "panel-subtitle"
            },
            {
              "_type": "stack",
              "class": "actions-row",
              "_children": [
                {
                  "_type": "button",
                  "_text": "Refresh",
                  "_variant": "secondary",
                  "_on": {
                    "_click": [
                      {
                        "_module": "xvm",
                        "_op": "list-apps",
                        "_params": {
                          "_env": "default",
                          "_include_system": false,
                          "_output": "system.apps"
                        }
                      }
                    ]
                  }
                },
                {
                  "_type": "button",
                  "_text": "+ Create App",
                  "_on": {
                    "_click": {
                      "_op": "open-object",
                      "_params": {
                        "_id": "generate-app-modal"
                      }
                    }
                  }
                }
              ]
            },
            {
              "_type": "table",
              "_id": "apps-table",
              "class": "apps-table",
              "_data_source": "system.apps",
              "_row_key": "_app_id",
              "_on": {
                "_wormhole-open": {
                  "_module": "xvm",
                  "_op": "list-apps",
                  "_params": {
                    "_env": "default",
                    "_include_system": false,
                    "_output": "system.apps"
                  }
                }
              },
              "_columns": [
                {
                  "_key": "_app_id",
                  "_title": "App"
                },
                {
                  "_key": "_env",
                  "_title": "Env"
                },
                {
                  "_key": "actions",
                  "_title": "Actions",
                  "_type": "actions",
                  "_actions": [
                    {
                      "_type": "button",
                      "_text": "Open",
                      "_variant": "primary",
                      "_on": {
                        "_click": {
                          "_module": "xvm",
                          "_op": "load-server-app",
                          "_params": {
                            "_app_id": "$row._app_id",
                            "_env": "$row._env"
                          }
                        }
                      }
                    },
                    {
                      "_type": "button",
                      "_text": "Set Default",
                      "_variant": "secondary",
                      "_on": {
                        "_click": {
                          "_module": "xvm",
                          "_op": "set-default-app",
                          "_params": {
                            "_app_id": "$row._app_id",
                            "_env": "$row._env"
                          }
                        }
                      }
                    }
                  ]
                }
              ],
              "_empty_text": "No apps yet",
              "_striped": true,
              "_hover": true,
              "_bordered": true
            }
          ]
        },
        {
          "_type": "modal",
          "_id": "generate-app-modal",
          "_open": false,
          "_title": "Generate App",
          "_size": "lg",
          "_closable": true,
          "_close_on_backdrop": true,
          "_children": [
            {
              "_id": "create-app-panel",
              "_type": "stack",
              "class": "panel apps-panel",
              "_children": [
                {
                  "_type": "label",
                  "_text": "Create New App",
                  "class": "panel-title"
                },
                {
                  "_type": "label",
                  "_text": "Choose a starter. The description is saved as project vision, not treated as a full app generation request.",
                  "class": "panel-subtitle"
                },
                {
                  "_type": "stack",
                  "class": "form-layout",
                  "_gap": 18,
                  "_children": [
                    {
                      "_type": "field",
                      "_label": "App ID",
                      "_control": {
                        "_type": "text",
                        "_id": "app-id",
                        "placeholder": "my-dashboard, agent-demo, game-test...",
                        "_text":""
                      },
                      "_data_output": "vibe._app_id",
                      "_update_data_source_event": "input"
                    },
                    {
                      "_type": "field",
                      "_label": "Describe what you're building (optional)",
                      "_control": {
                        "_type": "textarea",
                        "_id": "vision-input",
                        "rows": 5,
                        "placeholder": "E.g. A dashboard for hospital music playlists with users, playlists and playback controls..."
                      },
                      "_data_output": "vibe._vision",
                      "_update_data_source_event": "input"
                    },
                    {
                      "_type": "grid",
                      "class": "card-grid",
                      "_children": [
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "📊 Dashboard",
                          "_text": "Admin-style app with overview, KPI cards, table area and settings shell.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create Dashboard",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "dashboard",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "🤖 Agent",
                          "_text": "Agent workbench with prompt input, conversation area and agent settings.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create Agent",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "agent",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "🎮 Game",
                          "_text": "Game shell with start area, score/status panel and runtime state placeholder.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create Game",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "game",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "🔌 API / Admin",
                          "_text": "Management app for entities, API-style operations, records and configuration.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create API App",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "api",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "CRM / ERP",
                          "_text": "Management app for entities, records, relationships, pipelines and configuration.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create App",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "crm",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        },
                        {
                          "_type": "card",
                          "class": "card",
                          "_hide_image": true,
                          "_title": "🧱 Empty",
                          "_text": "Minimal valid Xpell app with a clean main view, ready for live mutation.",
                          "_actions": [
                            {
                              "_type": "button",
                              "_text": "Create Empty App",
                              "_variant": "primary",
                              "_on": {
                                "_click": [
                                  {
                                    "_module": "flow-client",
                                    "_op": "trigger",
                                    "_params": {
                                      "_flow_id": "flow-create-app-from-starter",
                                      "_event_payload": {
                                        "_starter_id": "empty",
                                        "_app_id": "$xdata:vibe._app_id",
                                        "_vision": "$xdata:vibe._vision"
                                      }
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "_type": "modal",
          "_id": "api-key-modal",
          "_open": false,
          "_title": "Developer Console API Key",
          "_size": "md",
          "_closable": true,
          "_close_on_backdrop": true,
          "_children": [
            {
              "_type": "field",
              "_label": "API Key",
              "_control": {
                "_type": "text",
                "_data_output": "settings.xpell_api_key"
              }
            }
          ],
          "_actions": [
            {
              "_type": "button",
              "_text": "Save",
              "_on": {
                "_click": [
                  {
                    "_module": "xai-client",
                    "_op": "set-api-key",
                    "_params": {
                      "_provider": "aime",
                      "_xdata_key": "settings.xpell_api_key",
                      "_result_key": "ai.connection",
                      "_error_key": "ai.error"
                    }
                  },
                  {
                    "_op": "close-object",
                    "_params": {
                      "_id": "api-key-modal"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}